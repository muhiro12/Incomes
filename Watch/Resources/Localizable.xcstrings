    "Open the paired iPhone app if recent items do not appear." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the paired iPhone app if recent items do not appear."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre la app del iPhone enlazado si no aparecen los elementos recientes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez l’app iPhone jumelée si les éléments récents n’apparaissent pas."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "最近の項目が表示されない場合は、ペアリング済みの iPhone アプリを開いてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果最近项目没有出现，请打开已配对的 iPhone 应用。"
          }
        }
      }
    },
    "Open the paired iPhone app, then try Reload again." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open the paired iPhone app, then try Reload again."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre la app del iPhone enlazado y vuelve a intentar Recargar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrez l’app iPhone jumelée, puis réessayez Recharger."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ペアリング済みの iPhone アプリを開いてから、もう一度再読み込みしてください。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请先打开已配对的 iPhone 应用，然后再次尝试重新加载。"
          }
        }
      }
    },
